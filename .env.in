# Upstream endpoint (no trailing slash or path)
UPSTREAM_BASE=https://my-resource.openai.azure.com/openai/v1

# Optional upstream API version
UPSTREAM_API_VERSION=preview

# Shared upstream key (fill in)
UPSTREAM_API_KEY=1234...9999

# Optional: change SQLite location
# DATABASE_PATH=./data/proxy.sqlite
# MODEL_PRICING_FILE=./data/model_pricing.azure.json

# Required for admin endpoints (choose a secret)
# ADMIN_TOKEN=changeme

### LDAP / Active Directory integration
# (so you can log in with existing credentials)
# Set USE_LDAP=1 if you want to use the configuration.
USE_LDAP=0

# LDAP_SERVER=ldap://your.ldap.server.com
# LDAP_DN=my-service-account
# LDAP_PW=my-service-account-password
# LDAP_SEARCH_BASE=OU=Users,DC=your,DC=ldap,DC=server,DC=com

### LDAP_FILTER contains a '%s' that will be replaced by the username
# LDAP_FILTER='(&(objectClass=person)(userPrincipalName=%s))'

# If LDAP_DOMAIN is given, it will be appended to the
# username when the given username doesn't contain a '@'
# LDAP_DOMAIN=@mydomain.com
